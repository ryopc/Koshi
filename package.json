{
  "name": "@ryopc/koshi",
  "version": "1.3.1",
  "description": "Terminal-native decentralized SNS — koshi board",
  "homepage": "https://koshi.js.org",
  "type": "module",
  "bin": {
    "kb": "bin/cli.js"
  },
  "scripts": {
    "dev": "nodemon --exec node bin/server.js",
    "dev:cli": "nodemon --exec node bin/cli.js",
    "start": "node bin/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest || true",
    "lint": "eslint . --ext .js || true",
    "migrate": "node src/db/migrate.js",
    "postinstall": "echo '🍄 Thank you for installing koshi! Type kb --help to get started.'"
  },
  "dependencies": {
    "@noble/ed25519": "^2.0.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "tweetnacl": "^1.0.3",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "eslint": "^8.50.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemon": "^3.0.1",
    "pg": "^8.11.3",
    "pino": "^8.14.1",
    "pino-pretty": "^10.2.0",
    "uuid": "^14.0.0"
  },
  "license": "MIT",
  "author": "ryopc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryopc/koshi.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "src/auth/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "sns",
    "decentralized",
    "terminal",
    "cli",
    "ed25519",
    "nostr"
  ]
}
