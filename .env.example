# PandaStack Environment Variables Template
# Copy to .env and fill in your values
# DO NOT commit .env to GitHub!

# ========================================
# Server Configuration
# ========================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ========================================
# Database (PandaStack auto-wired)
# ========================================
# This is auto-generated by PandaStack
# Do NOT modify manually in dashboard
DATABASE_URL=postgresql://koshi_user:password@db.pandastack.io:5432/koshi_db

# ========================================
# Authentication & Security
# ========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_random_secret_key_here_min_32_chars_long_keep_secure

# Ed25519 signing (optional, if server signs on behalf of users)
SERVER_PRIVATE_KEY=your_ed25519_private_key_base64_encoded

# ========================================
# API Configuration
# ========================================
# CORS origin (adjust for production)
CORS_ORIGIN=https://koshi.pandastack.app

# API rate limiting (requests per minute)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# ========================================
# WebSocket Configuration
# ========================================
# WebSocket connection timeout (ms)
WS_HEARTBEAT_INTERVAL=30000
WS_PING_TIMEOUT=60000

# ========================================
# Logging (optional)
# ========================================
LOG_LEVEL=info
LOG_FORMAT=json  # or 'text' for development

# ========================================
# Monitoring & Observability
# ========================================
# Application Insights / Datadog (optional)
MONITORING_ENABLED=false
MONITORING_API_KEY=your_monitoring_api_key_here

# ========================================
# Feature Flags (Phase 2+)
# ========================================
FEATURE_REACTIONS=false
FEATURE_COMMENTS=false
FEATURE_NOTIFICATIONS=false
FEATURE_SEARCH=false

# ========================================
# PandaStack Specific
# ========================================
# Health check endpoint (used by PandaStack monitoring)
HEALTH_CHECK_PATH=/health
