{
    "name": "koshi-api",
    "framework": "express",
    "buildCommand": "npm ci && npm run migrate",
    "startCommand": "node bin/server.js",
    "port": 3000,
    "env": {
        "DATABASE_URL": "$DATABASE_URL",
        "JWT_SECRET": "$JWT_SECRET",
        "NODE_ENV": "production",
        "LOG_LEVEL": "info"
    },
    "db": {
        "engine": "postgres",
        "version": "15"
    },
    "healthCheck": {
        "path": "/api/health",
        "interval": 30,
        "timeout": 5,
        "initialDelay": 10
    },
    "regions": ["us-east-1"],
    "scaling": {
        "min": 1,
        "max": 3,
        "targetConcurrency": 10
    }
}
