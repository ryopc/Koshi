# ============================================================================
# koshi – Terminal-Native Decentralized SNS
# Environment Variables
# License: MIT
# ============================================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit .env to version control! It contains secrets.
# ============================================================================

# === PostgreSQL Database ===
# Connection string for the PostgreSQL database.
# Format: postgresql://user:password@host:port/database
#
# Local development:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/koshi
#
# PandaStack production:
#   DATABASE_URL is set automatically by PandaStack. Do NOT set it manually.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/koshi

# === JWT Secret ===
# Secret key for signing JSON Web Tokens.
# Generate a strong random key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# === Server ===
# Port for the HTTP server (default: 3000)
PORT=3000

# Node environment: 'development' or 'production'
NODE_ENV=development

# === Logging ===
# Log level: 'debug', 'info', 'warn', 'error'
# In production (PandaStack), set to 'info' to reduce log volume.
LOG_LEVEL=debug

# === CORS ===
# Comma-separated list of allowed origins (optional, CLI clients don't need this)
# CORS_ORIGIN=http://localhost:3000
