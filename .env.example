# ============================================================================
# koshi – Terminal-Native Decentralized SNS
# Environment Variables (Example)
# License: MIT
# ============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For production (Render.com + Neon.tech):
#   Set these in the Render dashboard -> Environment Variables
# ============================================================================

# --- Required ---

# PostgreSQL connection string from Neon.tech
# Get this from your Neon project -> Connection Details -> Connection string
# Use the pooled connection string for production:
#   postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/koshi?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/koshi?sslmode=require

# Secret key for JWT signing
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# --- Optional ---

# Server port (Render sets this automatically)
# PORT=3000

# Node environment
# NODE_ENV=development

# Log level: debug, info, warn, error
# LOG_LEVEL=info
