# PandaStack Production Environment Template
# Used by PandaStack dashboard - DO NOT edit manually
# All values are set via PandaStack Settings → Environment Variables

# ========================================
# Auto-set by PandaStack (do not modify)
# ========================================
NODE_ENV=production
PORT=3000

# Auto-generated and wire-in by PandaStack
DATABASE_URL=${DATABASE_URL}
JWT_SECRET=${JWT_SECRET}

# ========================================
# PandaStack Monitoring (optional)
# ========================================
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30s
